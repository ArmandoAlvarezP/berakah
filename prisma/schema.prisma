
generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
}

model Alumno {
  id     Int    @id @default(autoincrement())
  nombre String @unique
  curp   String @unique
  Certificacion Certificacion[]
}

model Certificacion {
  id           String   @id @default(uuid())
  tipo         String
  especialidad String
  emisora      String
  autorizada   String
  fechaEmision DateTime
  folio        String   @unique

  // Relaciones 

  alumno Alumno @relation(fields: [alumnoID], references: [id])
  alumnoID Int
}

model User {
  nombre   String @unique
  password String
  role     Role
}
